[
  {
    "label": "Ruby: Copy FQN at Cursor",
    "command": "python3",
    "args": [
      "scripts/copy_ruby_fqn.py",
      "--file",
      "$ZED_FILE",
      "--row",
      "$ZED_ROW",
      "--column",
      "$ZED_COLUMN"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "never",
    "hide": "on_success"
  }
]
